@prefix rr:     <http://www.w3.org/ns/r2rml#> .
@prefix rml:    <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:     <http://semweb.mmlab.be/ns/ql#> .
@prefix schema: <https://schema.org/> .

<#InvoiceMap>
  rml:logicalSource [
    rml:source              "invoices.xml" ;
    rml:referenceFormulation ql:XPath ;
    rml:iterator            "/invoices/invoice"
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/invoice/{@id}" ;
    rr:class    schema:Invoice
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:identifier ;
    rr:objectMap [ rml:reference "@id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:customer ;
    rr:objectMap [ rr:template "http://example.org/customer/{customer/id}" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:totalPaymentDue ;
    rr:objectMap [ rml:reference "amount" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:paymentDueDate ;
    rr:objectMap [ rml:reference "issued" ]
  ] .

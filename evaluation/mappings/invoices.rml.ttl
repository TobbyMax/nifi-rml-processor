@prefix rr:     <http://www.w3.org/ns/r2rml#> .
@prefix rml:    <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:     <http://semweb.mmlab.be/ns/ql#> .
@prefix schema: <https://schema.org/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

<#InvoiceBenchMap>
  rml:logicalSource [
    rml:source              "input.xml" ;
    rml:referenceFormulation ql:XPath ;
    rml:iterator            "/invoices/invoice"
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/invoice/{id}" ;
    rr:class    schema:Invoice
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:identifier ;
    rr:objectMap [ rml:reference "id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:accountId ;
    rr:objectMap [ rml:reference "customer/id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:price ;
    rr:objectMap [
      rml:reference "amount" ;
      rr:datatype xsd:decimal
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:dateIssued ;
    rr:objectMap [
      rml:reference "issued" ;
      rr:datatype xsd:date
    ]
  ] .
